FROM python:3.11-slim

RUN pip install --no-cache-dir flask PyJWT bcrypt

WORKDIR /app

COPY tools_nuc/tul_auth/ tul_auth/
COPY tools_nuc/nach/panel_server.py .
COPY tools_nuc/nach/panel.html .

ENV DOCKER=1
ENV SUBPATH=/nach
ENV PORT=5009

EXPOSE 5009

CMD ["python3", "panel_server.py", "--no-browser", "--port", "5009"]
