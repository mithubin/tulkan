FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends ghostscript && rm -rf /var/lib/apt/lists/*
RUN pip install --no-cache-dir flask PyJWT bcrypt

WORKDIR /app

COPY tools_nuc/tul_auth/ tul_auth/
COPY tools_nuc/bild/bildseiteerstellen_panel.htm .
COPY tools_nuc/bild/panel_server.py .
COPY tools_nuc/bild/static/ static/

ENV DOCKER=1
ENV PORT=5005

EXPOSE 5005

CMD ["python3", "panel_server.py", "--no-browser", "--port", "5005"]
