FROM python:3.11-slim

RUN pip install --no-cache-dir flask PyJWT bcrypt

WORKDIR /app

COPY tools_nuc/tul_auth/ tul_auth/
COPY tools_nuc/kal-trel/panel_server.py .
COPY tools_nuc/kal-trel/panel.html .

ENV DOCKER=1
ENV SUBPATH=/kal-trel
ENV PORT=5010

EXPOSE 5010

CMD ["python3", "panel_server.py", "--no-browser", "--port", "5010"]
