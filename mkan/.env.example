# mkan — environment variables
# Copy to .env and fill in your values.

# Required
SECRET_KEY=change-me-use-openssl-rand-hex-32

# tul.yourdomain.example Bridge — nur nötig wenn tools_nuc-Integration (DV-Bridge) genutzt wird.
# Muss exakt mit TUL_BRIDGE_SECRET auf der tools_nuc-Seite übereinstimmen.
TUL_BRIDGE_SECRET=

# Database and uploads (adjust paths to match your volume mounts)
DB_PATH=/app/data/db/kanban.sqlite
UPLOAD_PATH=/app/data/uploads

# Base URL of this instance (used in invitation/reset mails)
MKAN_BASE_URL=https://mkan.yourdomain.example

# OnlyOffice — optional, enables .docx/.xlsx/.pptx editing
# Leave empty to run without OnlyOffice
OO_URL=
OO_MKAN_BASE=
OO_SECRET=

# SMTP — optional, enables invitation and password-reset mails
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
